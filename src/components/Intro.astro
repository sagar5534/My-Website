---
const portrait = "/profile.png";
---

<section
  id="about"
  class="px-margin-mobile md:px-margin-page py-section-gap border-y border-outline-variant bg-canvas"
>
  <div class="max-w-7xl mx-auto flex flex-col md:flex-row gap-16 items-center">
    <div
      class="w-full md:w-1/3 aspect-[4/5] rounded-xl overflow-hidden"
    >
      <img
        class="w-full h-full object-cover"
        src={portrait}
        alt="Portrait of Sagar Patel"
      />
    </div>
    <div class="w-full md:w-2/3">
      <h2 class="font-headline-lg text-headline-lg mb-stack-md">Hey! I'm Sagar.</h2>
      <div class="space-y-6 max-w-2xl">
        <p
          class="font-body-md text-body-md leading-relaxed text-on-surface-variant"
        >
          I'm a Senior Software Engineer at PointClickCare, building scalable
          microservices and RESTful APIs that power real-time data
          visualization for over 2 million patients using Java, SQL, and
          TypeScript.
        </p>
        <p
          class="font-body-md text-body-md leading-relaxed text-on-surface-variant"
        >
          I care about reliability and craft—whether that's cutting QA testing
          time by 40% with a browser-based automation framework, optimizing
          page load times, or facilitating sprint planning as a Certified
          ScrumMaster. I build software that's fast, secure, and easy to trust.
        </p>
        <div class="flex gap-4 pt-4">
          <span class="text-outline-variant">/</span>
          <a
            class="text-primary hover:underline font-ui-text text-[16px] font-bold"
            href="#contact">GET IN TOUCH</a
          >
        </div>
      </div>
    </div>
  </div>
</section>
