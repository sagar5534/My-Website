---
const links = [
  { label: "LinkedIn", href: "#", icon: "linkedin" },
  { label: "GitHub", href: "#", icon: "github" },
  { label: "Email", href: "mailto:hello@majd.com", icon: "mail" },
  { label: "Resume", href: "#", icon: "description" },
];

// Brand glyphs (Material Symbols has no brand logos) vs. Material Symbols.
const brandIcons = ["linkedin", "github"];
---

<section
  id="contact"
  class="px-margin-mobile md:px-margin-page py-section-gap border-t border-outline-variant bg-canvas"
>
  <div class="max-w-7xl mx-auto">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8">
      <div class="lg:col-span-4">
        <h2 class="font-headline-lg text-headline-lg uppercase">Let's Connect</h2>
        <p
          class="font-ui-text text-body-md leading-relaxed text-on-surface-variant mt-4 max-w-sm"
        >
          Currently open to new engineering challenges, collaborative
          open-source projects
        </p>
      </div>
      <div class="lg:col-span-8">
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          {
            links.map((link) => (
              <a
                class="flex items-center justify-between bg-primary text-on-primary p-6 rounded-xl hover:scale-[1.02] transition-transform group"
                href={link.href}
              >
                <div class="flex items-center gap-4">
                  {link.icon === "linkedin" ? (
                    <svg
                      class="w-6 h-6 fill-current shrink-0"
                      viewBox="0 0 24 24"
                      aria-hidden="true"
                    >
                      <path d="M20.45 20.45h-3.56v-5.57c0-1.33-.02-3.04-1.85-3.04-1.85 0-2.14 1.45-2.14 2.94v5.67H9.34V9h3.42v1.56h.05c.48-.9 1.64-1.85 3.37-1.85 3.6 0 4.27 2.37 4.27 5.46v6.28zM5.34 7.43a2.07 2.07 0 1 1 0-4.14 2.07 2.07 0 0 1 0 4.14zM7.12 20.45H3.55V9h3.57v11.45zM22.22 0H1.77C.79 0 0 .77 0 1.73v20.54C0 23.22.79 24 1.77 24h20.45c.98 0 1.78-.78 1.78-1.73V1.73C24 .77 23.2 0 22.22 0z" />
                    </svg>
                  ) : link.icon === "github" ? (
                    <svg
                      class="w-6 h-6 fill-current shrink-0"
                      viewBox="0 0 24 24"
                      aria-hidden="true"
                    >
                      <path d="M12 .3a12 12 0 0 0-3.79 23.39c.6.11.82-.26.82-.58v-2.03c-3.34.73-4.04-1.61-4.04-1.61-.55-1.39-1.34-1.76-1.34-1.76-1.08-.74.09-.73.09-.73 1.2.09 1.83 1.24 1.83 1.24 1.07 1.84 2.81 1.3 3.49.99.11-.78.42-1.3.76-1.6-2.67-.3-5.47-1.34-5.47-5.95 0-1.32.47-2.39 1.24-3.23-.13-.31-.54-1.53.12-3.18 0 0 1-.32 3.3 1.23a11.5 11.5 0 0 1 6 0c2.28-1.55 3.29-1.23 3.29-1.23.66 1.65.25 2.87.12 3.18.77.84 1.23 1.91 1.23 3.23 0 4.62-2.8 5.64-5.48 5.94.43.37.81 1.1.81 2.22v3.29c0 .32.22.7.83.58A12 12 0 0 0 12 .3z" />
                    </svg>
                  ) : (
                    <span class="material-symbols-outlined text-2xl shrink-0">
                      {link.icon}
                    </span>
                  )}
                  <span class="font-headline-sm text-[20px] font-bold">
                    {link.label}
                  </span>
                </div>
                <span class="material-symbols-outlined text-xl group-hover:translate-x-1 transition-transform">
                  north_east
                </span>
              </a>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</section>
